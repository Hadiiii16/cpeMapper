# Free NVD API key (https://nvd.nist.gov/developers/request-an-api-key).
# Without a key the downloader still works but is ~10x slower (5 req / 30s vs 50 req / 30s).
NVD_API_KEY=

# Free Google AI Studio API key (https://aistudio.google.com/apikey).
# When set, gemini_rank.py uses generativelanguage.googleapis.com
# (free tier: 10 RPM gemini-2.5-flash, 15 RPM gemini-2.5-flash-lite).
# If unset, gemini_rank.py falls back to OAuth via ~/.gemini/oauth_creds.json
# (the same path gemini-cli uses), which has a much tighter ~1 RPM quota.
GEMINI_API_KEY=

# Default model for ranking. Pass --model on the CLI to override.
# Comma-separated values enable round-robin across models.
# Recommended on free tier: gemini-2.5-flash-lite (highest RPM, good enough quality).
GEMINI_MODEL=gemini-2.5-flash-lite
